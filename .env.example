# Chiqimlar - Muhit o'zgaruvchilari
# Nusxalang: .env.example ni .env ga va to'ldiring

# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.ngrok.io

# Database (PostgreSQL). Bo'sh qoldirsangiz SQLite ishlatiladi (ishlab chiqish uchun).
# DATABASE_URL=postgres://user:password@localhost:5432/chiqimlar_db

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=random_secret_for_webhook_verification
TELEGRAM_WEBAPP_URL=https://your-domain.com
TELEGRAM_BOT_USERNAME=your_bot_username
OCRSPACE_API_KEY=
CURRENCY_RATES_TO_UZS={"UZS":1,"USD":12500,"EUR":13500,"RUB":140}

# Celery / Redis (optional)
CELERY_BROKER_URL=redis://localhost:6379/0

# Timezone (UTC+5)
TIME_ZONE=Asia/Tashkent

# Security (production)
CSRF_TRUSTED_ORIGINS=https://your-domain.com
SECURE_SSL_REDIRECT=False
